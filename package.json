{
  "name": "treact",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@testing-library/jest-dom": "^5.16.0",
    "@testing-library/react": "^13.4.0",
    "@testing-library/user-event": "^14.4.3",
    "@vercel/kv": "^3.0.0",
    "feather-icons": "^4.29.0",
    "framer-motion": "^7.3.2",
    "google-reviews-widget": "^1.0.4",
    "nodemailer": "^8.0.3",
    "react": "^18.0.0",
    "react-anchor-link-smooth-scroll": "^1.0.12",
    "react-dom": "^18.0.0",
    "react-github-btn": "^1.4.0",
    "react-modal": "^3.15.0",
    "react-rnd": "^10.3.7",
    "react-router-dom": "^6.3.0",
    "react-scripts": "5.0.1",
    "react-slick": "^0.29.0",
    "slick-carousel": "^1.8.1",
    "styled-components": "^5.3.5",
    "tailwindcss": "^3.0.0",
    "twin.macro": "^3.0.0-rc.4"
  },
  "scripts": {
    "start": "cross-env PORT=3001 NODE_OPTIONS=--openssl-legacy-provider react-scripts start",
    "dev:vercel": "npx vercel dev",
    "build": "cross-env NODE_OPTIONS=--openssl-legacy-provider react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "deploy": "npm run build && netlify deploy --prod",
    "convert-heic": "node scripts/convert-heic-to-web.js",
    "sync-icon-colors": "node scripts/sync-icon-colors-to-primary.js"
  },
  "eslintConfig": {
    "extends": "react-app",
    "overrides": [
      {
        "files": [
          "src/**/*.js"
        ],
        "rules": {
          "import/no-anonymous-default-export": "off"
        }
      },
      {
        "files": [
          "api/**/*.js"
        ],
        "env": {
          "node": true
        }
      }
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "heic-convert": "^2.1.0",
    "sharp": "^0.34.5"
  }
}
