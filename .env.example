# Variables para la función serverless `api/send-email.js` (Vercel o `vercel dev`).
# Copia este archivo como .env en la raíz del proyecto para desarrollo local con Vercel CLI.
#
# En producción: define las mismas variables en Vercel → Project → Settings → Environment Variables.
#
# El frontend en desarrollo usa el puerto 3001 (ver package.json `npm start`).

# Gmail (contraseña de aplicación; los espacios en EMAIL_PASSWORD se ignoran)
EMAIL_USER=tu-email@gmail.com
EMAIL_PASSWORD=xxxx xxxx xxxx xxxx

# Donde recibir los mensajes del formulario
RECIPIENT_EMAIL=csilva2527@gmail.com

# Opcional: solo si el API vive en otro dominio (el formulario usa /api/send-email por defecto)
# REACT_APP_EMAIL_API_URL=https://tu-dominio.vercel.app

# --- Panel admin /walk-in (api/admin-*.js, api/public-walkin.js) ---
# Crear proyecto KV en Vercel y enlazar; el CLI rellena automáticamente:
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
ADMIN_USERNAME=admin
ADMIN_PASSWORD=cambia-esto-por-una-contrasena-larga
ADMIN_JWT_SECRET=genera-un-secreto-largo-aleatorio
